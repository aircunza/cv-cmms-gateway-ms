######################## ORGANIZATIONS ########################
@baseUrl = http://localhost:3000/api/v1
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..sdagZOqJcyzjtOmBNIcNWnex8nEdCh7PZvemQ9n1KSU
@orgId =483eb41f-3442-40fb-bf31-68e908fc6422

### Create organization
POST {{baseUrl}}/organizations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "ORG-BOG-001",
  "name": "CMMS Colombia",
  "countryCode": "CO",
  "countryName": "Colombia",
  "timezone": "America/Bogota",
  "offsetMinutes": -300
}

### Get one organization
GET {{baseUrl}}/organizations/{{orgId}}
Authorization: Bearer {{token}}

### Get organizations (all active by default)
GET {{baseUrl}}/organizations
Authorization: Bearer {{token}}

### Get organizations filtered by code
GET {{baseUrl}}/organizations?code=ORG-BOG
Authorization: Bearer {{token}}

### Get organizations filtered by name
GET {{baseUrl}}/organizations?name=CMMS
Authorization: Bearer {{token}}

### Get organizations filtered by countryCode
GET {{baseUrl}}/organizations?countryCode=CO
Authorization: Bearer {{token}}

### Update organization (partial)
PATCH {{baseUrl}}/organizations/{{orgId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "CMMS Colombia S.A.S.",
  "timezone": "America/Bogota",
  "offsetMinutes": -200
}

### Update organization (change code)
PATCH {{baseUrl}}/organizations/{{orgId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "CMMS Colombia S.A.S."
}

### Deactivate organization (soft delete)
PATCH {{baseUrl}}/organizations/{{orgId}}/deactivate
Authorization: Bearer {{token}}




######################## USER ORG PERMISSIONS ########################
@uopUserId = afa6ad1b-b758-4ca5-a207-42943f8c64a2
@uopOrgId = 483eb41f-3442-40fb-bf31-68e908fc6422
@uopId = 00000000-0000-0000-0000-000000000000

### Create user org permission
POST {{baseUrl}}/user-org-permissions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "userId": "{{uopUserId}}",
  "organizationId": "{{uopOrgId}}",
  "roleCode": "manager",
  "roleName": "Manager",
  "roleDescription": "Organization manager role",
  "permissions": ["users.read", "users.create"],
  "deniedPermissions": ["users.delete"]
}

### Nota: copia el id devuelto en create y pegalo en @uopId

### Get one user org permission (active only)
GET {{baseUrl}}/user-org-permissions/{{uopId}}
Authorization: Bearer {{token}}

### Get user org permissions (all active by default)
GET {{baseUrl}}/user-org-permissions
Authorization: Bearer {{token}}

### Get user org permissions filtered by userId
GET {{baseUrl}}/user-org-permissions?userId={{uopUserId}}
Authorization: Bearer {{token}}

### Get user org permissions filtered by organizationId
GET {{baseUrl}}/user-org-permissions?organizationId={{uopOrgId}}
Authorization: Bearer {{token}}

### Get user org permissions filtered by roleCode
GET {{baseUrl}}/user-org-permissions?roleCode=manager
Authorization: Bearer {{token}}

### Get user org permissions including inactive
GET {{baseUrl}}/user-org-permissions?isActive=N
Authorization: Bearer {{token}}

### Update user org permission (partial)
PATCH {{baseUrl}}/user-org-permissions/{{uopId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "roleName": "Manager Senior",
  "roleDescription": "Organization manager role with broader scope",
  "permissions": ["users.read", "users.create", "users.update"],
  "deniedPermissions": []
}

### Deactivate user org permission (soft delete)
PATCH {{baseUrl}}/user-org-permissions/{{uopId}}/deactivate
Authorization: Bearer {{token}}

